# --- Public backend (production-style) ---
# Uncomment and set when the API runs on another host than the SPA.
# VITE_API_BASE_URL=https://your-api-host.example/api
# VITE_SOCKET_URL=https://your-api-host.example
#
# --- Local backend (default for dev) ---
VITE_API_BASE_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_SOCKET_PATH=/socket.io
VITE_APP_NAME=Wazzfly Admin
VITE_DEFAULT_CURRENCY=USD
VITE_ENABLE_ADMIN_PROJECT_CREATE=false
VITE_NOTIFICATIONS_POLL_MS=30000
VITE_DASHBOARD_REFRESH_MS=60000
VITE_SENTRY_DSN=
